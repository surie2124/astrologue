# .env.example
# 실제 사용 시 이 파일을 복사하여 .env 로 저장하고 값을 채워 넣을 것.
# .env 파일은 절대 git에 커밋하지 말 것 (.gitignore에 추가 필수)

# OpenAI API 키
OPENAI_API_KEY=sk-...

# 토스페이먼츠 클라이언트 키 (프론트엔드용 — 공개 가능)
TOSS_CLIENT_KEY=test_ck_...

# 토스페이먼츠 시크릿 키 (서버 전용 — 절대 노출 금지)
TOSS_SECRET_KEY=test_sk_...

# Flask 세션 암호화 키 (임의의 긴 랜덤 문자열)
FLASK_SECRET_KEY=여기에_긴_랜덤_문자열을_입력하세요
